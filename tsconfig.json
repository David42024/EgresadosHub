{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "declaration": true,
    "paths": {
      "@repo/trpc-contract": ["./packages/trpc-contract/src/index.ts"],
      "@repo/trpc-contract/*": ["./packages/trpc-contract/src/*"]
    }
  }
}